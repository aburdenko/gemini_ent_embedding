# For local development, you can set the domain here.
# This will be overridden by the --domain argument if provided.
# Valid values are podcast, biotech or gcp_ai
DOMAIN=gcp_ai

GOOGLE_GENAI_USE_VERTEXAI=true

# Replace with your project ID
GCP_PROJECT_ID=your-gcp-project-id
GCP_PROJECT_NUMBER=your-gcp-project-number

# Replace with your GCP region
GCP_REGION=global
GEMINI_DATA_STORE_ID=your-data-store-id

# Replace with your GCP credentials file (if not using Application Default Credentials)
SERVICE_ACCOUNT_KEY_FILE=./service_account.json

GEMINI_MODEL_NAME=gemini-3-pro-preview

# --- Researcher Agent ---
# Models: gemini-1.5-flash, gemini-3-pro-preview, gemini-1.0-pro
RESEARCHER_MODEL=gemini-3-pro-preview

# --- Writer Agent ---
# Models: gemini-1.5-flash, gemini-3-pro-preview, gemini-1.0-pro
WRITER_MODEL=gemini-3-pro-preview

# --- Monetizer Agent ---
# Models: gemini-1.5-flash, gemini-3-pro-preview, gemini-1.0-pro
MONETIZER_MODEL=gemini-3-pro-preview


# --- Publishing ---
# Replace with the path to your Medium cookies file
MEDIUM_COOKIES_FILE=./medium_cookies.json

# Replace with your Medium username
MEDIUM_ACCOUNT=your.email@example.com
SUBSTACK_ACCOUNT=your_substack_account

# Replace with the path to your Substack cookies file
SUBSTACK_COOKIES_FILE=./substack_cookies.json

# Replace with your Substack URL
SUBSTACK_URL=https://your_substack.substack.com/

# --- Monetization ---
# Replace with the path to your image for the X post
X_IMAGE_PATH=./image.png

# --- Evaluation ---
EVAL_MODEL=gemini-3-pro-preview
EVAL_DATASET_PATH=./tests/eval_dataset.jsonl

# --- Environment ---
# Set to "local" or "gcp"
ENVIRONMENT=local

# Replace with your GCP Artifact Registry repository
GCP_AR_REPO=your-ar-repo

# Replace with your GCP service account
GCP_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com

AUTHOR_NAME=Your Name
MARKDOWN_FILE_PATH=./path/to/markdown.md

#GEMINI_API_KEY=your_gemini_api_key

# --- Gemini Enterprise Private Embedding ---
# Replace with your Gemini Enterprise (Vertex AI Search) URL
GEMINI_ENTERPRISE_URL="your_vertex_ai_search_url"
# --- Authentication ---
# Set to true to use Identity-Aware Proxy (IAP) for end-user authentication instead of service account
USE_IAP_AUTH=false
