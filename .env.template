# Replace with your project ID
GCP_PROJECT_ID=your-gcp-project-id

# Replace with your GCP region
GCP_REGION=global

# Replace with your Gemini Enterprise Data Store ID
GEMINI_DATA_STORE_ID=your-data-store-id

# Replace with your GCP credentials file (if not using Application Default Credentials)
SERVICE_ACCOUNT_KEY_FILE=./service_account.json

# --- Authentication ---
# Set to true to use Identity-Aware Proxy (IAP) for end-user authentication instead of service account
USE_IAP_AUTH=false
